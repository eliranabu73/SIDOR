{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "npm install --include=dev",
  "buildCommand": "npx prisma generate",
  "framework": null,
  "outputDirectory": ".vercel-empty",
  "functions": {
    "api/index.ts": {
      "runtime": "@vercel/node@3.2.24",
      "maxDuration": 30,
      "includeFiles": "node_modules/satori/**,node_modules/@resvg/resvg-js/**,node_modules/yoga-wasm-web/**"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index.ts" }
  ]
}
